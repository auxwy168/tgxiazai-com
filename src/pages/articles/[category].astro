---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/siteConfig';
import { getCollection } from 'astro:content';

// Generate static paths for all categories
export async function getStaticPaths() {
  return siteConfig.categories.map(cat => ({
    params: { category: cat.id },
  }));
}

const { category } = Astro.params;
const catInfo = siteConfig.categories.find(c => c.id === category);

if (!catInfo) return Astro.redirect('/articles/');

const all = await getCollection('articles', ({ data }) => !data.draft && data.category === category);
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const canonical = `${siteConfig.url}/articles/${category}/`;

const catCss = `
.articles-page{max-width:1100px;margin:40px auto;padding:0 24px}
.articles-page h1{font-size:1.8rem;text-align:center;margin-bottom:8px}
.subtitle{text-align:center;color:#64748b;margin-bottom:24px}
.cat-filters{display:flex;justify-content:center;gap:8px;margin-bottom:32px;flex-wrap:wrap}
.cat-filter{padding:6px 18px;border-radius:20px;font-size:13px;text-decoration:none;color:#475569;background:#f1f5f9;transition:all .2s}
.cat-filter:hover{background:#e0f2fe;color:#0369a1}
.cat-filter.active{background:${siteConfig.colors.primary};color:#fff}
.art-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.art-card{background:#fff;border:1px solid #e8ecf1;border-radius:14px;overflow:hidden;transition:transform .2s,box-shadow .2s;display:block;text-decoration:none;color:inherit}
.art-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.06)}
.art-img img{width:100%;height:180px;object-fit:cover}
.art-info{padding:16px 20px 20px}
.art-cat{display:inline-block;font-size:11px;padding:3px 10px;border-radius:6px;margin-bottom:8px}
.art-title{font-size:1rem;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;color:#1e293b}
.art-desc{color:#64748b;font-size:.85rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.art-meta{margin-top:12px;font-size:.8rem;color:#94a3b8}
.empty-state{text-align:center;padding:60px 20px;color:#94a3b8}
.empty-state p{font-size:15px;margin-bottom:16px}
.empty-state a{padding:10px 24px;background:${siteConfig.colors.primary};color:#fff;border-radius:8px;font-size:14px;text-decoration:none;display:inline-block}
@media(max-width:768px){.art-grid{grid-template-columns:1fr 1fr}}
@media(max-width:480px){.art-grid{grid-template-columns:1fr}}
`;
---

<BaseLayout
  title={`${catInfo.name} — ${siteConfig.title}`}
  description={`${catInfo.name}相关Telegram教程合集，共${sorted.length}篇深度文章。` + siteConfig.description}
  canonicalURL={canonical}
>
  <section class="articles-page">
    <h1>{catInfo.name}</h1>
    <p class="subtitle">{catInfo.name}相关教程 · 共 {sorted.length} 篇</p>

    <div class="cat-filters">
      <a href="/articles/" class="cat-filter">全部</a>
      {siteConfig.categories.map(c =>
        <a href={`/articles/${c.id}/`} class:list={["cat-filter", { active: category === c.id }]}>{c.name}</a>
      )}
    </div>

    {sorted.length === 0 ? (
      <div class="empty-state">
        <p>该分类暂无文章</p>
        <a href="/articles/">浏览全部教程</a>
      </div>
    ) : (
      <div class="art-grid">
        {sorted.map(a => {
          const cat = a.data.category;
          return (
            <a href={`/${a.id}/`} class="art-card">
              {a.data.coverImage && <div class="art-img"><img src={a.data.coverImage} alt={a.data.title} loading="lazy" /></div>}
              <div class="art-info">
                <span class="art-cat">{siteConfig.catLabels[cat] || cat}</span>
                <h3 class="art-title">{a.data.title}</h3>
                <p class="art-desc">{a.data.description}</p>
                <div class="art-meta"><span>{a.data.date.toISOString().slice(0, 10)}</span></div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>

<style set:html={catCss} />

<!-- Schema -->
<script type="application/ld+json" set:html={JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${catInfo.name} — ${siteConfig.name}`,
    description: `${catInfo.name}相关Telegram教程合集`,
    url: canonical,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首页', item: siteConfig.url },
      { '@type': 'ListItem', position: 2, name: '所有教程', item: siteConfig.url + '/articles/' },
      { '@type': 'ListItem', position: 3, name: catInfo.name },
    ],
  },
])} />
